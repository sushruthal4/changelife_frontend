{
  "name": "changeliferontendproject",
  "main": "dist/server/server.js",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS"
  },
  "routes": [
    {
      "pattern": "changelife.in/*",
      "zone_name": "changelife.in"
    }
  ]
}